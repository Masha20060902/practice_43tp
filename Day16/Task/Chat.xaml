<Window x:Class="Task.Chat"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Task"
        mc:Ignorable="d"
        Title="Chat" Height="450" Width="800" WindowStartupLocation="CenterScreen">
    <Grid>
        <TextBox Text="{Binding MessageText,UpdateSourceTrigger=PropertyChanged}" 
                 Margin="0,0,179,10" 
                 HorizontalAlignment="Right" 
                 Width="592" 
                 Height="71" 
                 VerticalAlignment="Bottom"/>
        <Button Content="Отправить" 
                Command="{Binding SendMessageCommand}" 
                Margin="0,0,16,20" 
                HorizontalAlignment="Right" 
                Width="142" 
                Height="40" 
                VerticalAlignment="Bottom"/>
        <ListBox ItemsSource="{Binding ChatMessage}" 
                 HorizontalAlignment="Center" 
                 Width="742" 
                 Height="316" 
                 VerticalAlignment="Bottom" 
                 Margin="0,0,0,81"/>
    </Grid>
</Window>

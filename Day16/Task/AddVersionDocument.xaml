<Window x:Class="Task.AddVersionDocument"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Task"
        mc:Ignorable="d"
        Title="Добавить версию..." Height="239" Width="348" WindowStartupLocation="CenterScreen" Background="#FFE8E8E8" ResizeMode="NoResize" SizeToContent="WidthAndHeight">
    <Grid Margin="0,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="20*"/>
            <RowDefinition Height="39*"/>
            <RowDefinition Height="41*"/>
            <RowDefinition Height="46*"/>
            <RowDefinition Height="57*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="19*"/>
            <ColumnDefinition Width="32*"/>
        </Grid.ColumnDefinitions>

        <Label Content="Номер версии" Margin="17,4,10,7" Grid.Row="1"/>
        <TextBox x:Name="Version" TextWrapping="Wrap" Text="" HorizontalScrollBarVisibility="Auto" Panel.ZIndex="-1" Margin="15,5,28,7" Grid.Column="1" Grid.Row="1"/>

        <Label Content="Дата" Margin="17,8,24,5" Grid.Row="2"/>
        <TextBox x:Name="Date" TextWrapping="Wrap" Text="" HorizontalScrollBarVisibility="Auto" Panel.ZIndex="-1" Margin="15,8,28,5" Grid.Column="1" Grid.Row="2"/>
        <Label Content="Автор" Margin="17,14,28,6" Grid.Row="3"/>
        <TextBox x:Name="Author" TextWrapping="Wrap" Text="" HorizontalScrollBarVisibility="Auto" Panel.ZIndex="-1" Margin="15,14,28,6" Grid.Column="1" Grid.Row="3"/>
        <StackPanel  Grid.Column="1" Grid.Row="4"
                     HorizontalAlignment="Center"
                     Orientation="Horizontal" VerticalAlignment="Center" Width="218" Height="63">
            <Button x:Name="AddV" Click="AddV_Click" Height="25" Width="84" Margin ="15,0,25,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="LightCoral" CornerRadius="9">
                            <ContentPresenter Content="Добавить" HorizontalAlignment="Center" VerticalAlignment="Center">
                            </ContentPresenter>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Отмена"  Foreground="Black" BorderBrush="#FF9D9D9D" Click="Button_Click" Height="26" Width="66"/>
        </StackPanel>
    </Grid>

</Window>

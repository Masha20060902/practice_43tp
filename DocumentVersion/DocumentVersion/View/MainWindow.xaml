<Window x:Class="DocumentVersion.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DocumentVersion"
        xmlns:Collections="clr-namespace:System.Collections;assembly=System.Runtime"
        mc:Ignorable="d"
        Title="Контроль версий"
        Width="800"
        Height="450"
        WindowStartupLocation="CenterScreen"
        Loaded="MainWindow_Loaded"
        Closed="Window_Closed"
        Background="{DynamicResource AppBackgroundBrush}"
        Foreground="{DynamicResource AppForegroundBrush}">
    <Window.Resources>
        <Storyboard x:Key="ShowVersionStoryboard">
            <DoubleAnimation Storyboard.TargetName="VersionContent"
                         Storyboard.TargetProperty="Opacity"
                         From="0" To="1"
                         Duration="0:0:0.25"/>

            <DoubleAnimation Storyboard.TargetName="VersionTransform"
                         Storyboard.TargetProperty="Y"
                         From="20" To="0"
                         Duration="0:0:0.25"/>
        </Storyboard>
    </Window.Resources>
    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="ApplicationCommands.New" />
        <KeyBinding Key="D" Modifiers="Control" Command="ApplicationCommands.Delete" />
        <KeyBinding Key="H" Modifiers="Control" Command="ApplicationCommands.Paste" />
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.New" Executed="AddVersionDoc_Click" />
        <CommandBinding Command="ApplicationCommands.Delete" Executed="DeleteVersion_Click" />
        <CommandBinding Command="ApplicationCommands.Paste" Executed="ViewHistory_Click" />
    </Window.CommandBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Menu Grid.Row="0"
              Margin="1,0,0,0"
              IsEnabled="True"
              Height="18"
              VerticalAlignment="Top"
              Background="{DynamicResource ControlBackgroundBrush}"
              Foreground="{DynamicResource AppForegroundBrush}">
            <MenuItem Header="Файл">
                <MenuItem x:Name="ViewHistory"
                            Header="Просмотреть историю"
                            Click="ViewHistory_Click"
                            InputGestureText="Ctrl+H"/>
            </MenuItem>
            <MenuItem Header="Документы">
                <MenuItem x:Name="AddDoc"
                          Header="Добавить документ"
                          Click="AddDoc_Click"/>
            </MenuItem>
            <MenuItem Header="Версии">
                <MenuItem x:Name="AddVersionDoc"
                            Header="Добавить версию"
                            Click="AddVersionDoc_Click"
                            InputGestureText="Ctrl+N"/>
                <MenuItem x:Name="DeleteVersion"
                            Header="Удалить версию"
                            Click="DeleteVersion_Click"
                            InputGestureText="Ctrl+D"/>
                <MenuItem Header="Показать первую версию"
                          Command="{Binding ShowFirstVersionCommand}"/>
                <MenuItem Header="Добавить коментарий к версии"
                          Click="MenuItem_Click_1"/>
            </MenuItem>
            <MenuItem Header="Настройки">
                <MenuItem x:Name="ThemeMenuItem"
                      Header="Переключиться на тёмную тему"
                      Click="ThemeMenuItem_Click"/>
            </MenuItem>
            <MenuItem Header="Чат"
                      Height="18"
                      Width="33"
                      Click="MenuItem_Click"/>
        </Menu>
        <Grid Grid.Row="1" Margin="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TreeView x:Name="DocumentsTreeView"
                Grid.Column="0"
                Margin="0,0,6,0"
                ItemsSource="{Binding Documents}"
                SelectedItemChanged="DocumentsTreeView_SelectedItemChanged"
                      Template="{DynamicResource AppTreeViewTemplate}"
                      ItemTemplate="{DynamicResource DocumentTreeItemTemplate}">
            </TreeView>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <DataGrid x:Name="DataGrid"
                            Grid.Row="0"
                            Margin="0,0,0,6"
                            AutomationProperties.IsColumnHeader="True"
                            Foreground="#FF484545"
                            AutoGenerateColumns="False"
                            Background="White"
                            ScrollViewer.CanContentScroll="True"
                            BorderBrush="Black"
                            SelectionMode="Single"
                            SelectionUnit="FullRow"
                            ItemsSource="{Binding Versions}"
                            SelectedItem="{Binding SelectedVersion, Mode=TwoWay}"
                            RowDetailsVisibilityMode="VisibleWhenSelected"
                            SelectionChanged="DataGrid_SelectionChanged">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Номер версии"
                                            Binding="{Binding VersionNumber}"
                                            Width="150"
                                            IsReadOnly="True"/>
                        <DataGridTextColumn Header="Дата"
                                            Binding="{Binding CreatedAt,StringFormat=yyyy-MM-dd}"
                                            Width="160"/>
                        <DataGridTextColumn Header="Автор"
                                            Binding="{Binding Author}"
                                            Width="300"/>
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                    <Setter Property="Background" Value="#FFFFF5B5"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.RowDetailsTemplate>
                        <DataTemplate>
                            <Border Background="LightBlue"
                                    Opacity="0">
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation
                                                    Storyboard.TargetProperty="Opacity"
                                                    From="0" To="1"
                                                    Duration="0:0:0.25"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                                <StackPanel Orientation="Vertical" Margin="0">
                                    <TextBlock Background="LightCyan">
                                        Версия: <Run Text="{Binding VersionNumber}"/>
                                    </TextBlock>
                                    <TextBlock>
                                        Дата: <Run Text="{Binding CreatedAt, StringFormat=yyyy-MM-dd}"/>
                                    </TextBlock>
                                    <TextBlock>
                                        Изменение: <Run Text="{Binding Title}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </DataGrid.RowDetailsTemplate>
                </DataGrid>
                <Border x:Name="VersionBorder"
                    Grid.Row="1"
                    Style="{DynamicResource VersionBorderStyle}">
                    <Grid x:Name="VersionContent"
                        Opacity="0">
                        <Grid.RenderTransform>
                            <TranslateTransform x:Name="VersionTransform" X="0" Y="20"/>
                        </Grid.RenderTransform>
                        <StackPanel Margin="10">
                            <TextBlock x:Name="VerNumber" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock x:Name="VerDate" Margin="0,0,0,3"/>
                            <TextBlock x:Name="VerAuthor" Margin="0,0,0,3"/>
                            <TextBlock x:Name="VerComment" Margin="0,5,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
        <Grid x:Name="LoadingOverlay"
              Grid.RowSpan="3"
              Visibility="Collapsed"
              Background="#80636364">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock Text="Загрузка..."
                           Foreground="{DynamicResource OverlayTextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>
                <ProgressBar x:Name="LoadProgress"
                             Minimum="0"
                             Maximum="100"
                             Width="200"
                             Height="20"
                             IsIndeterminate="True"
                             Foreground="#FF0B48AB"
                             Background="#FFC5C5C5"
                             BorderBrush="#FF231717"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>
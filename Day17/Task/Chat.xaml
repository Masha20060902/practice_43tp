<Window x:Class="Task.Chat"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Task"
        mc:Ignorable="d"
        Title="Чат" 
        Height="470" 
        Width="800" 
        WindowStartupLocation="CenterScreen">
    <Grid Margin="67,0,67,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="275"/>
            <RowDefinition Height="92"/>
            <RowDefinition Height="61"/>
        </Grid.RowDefinitions>
        <StackPanel>
            <Label Content="Чат сотрудников" FontWeight="Medium"/>
            <ListBox ItemsSource="{Binding ChatMessage}" Height="246">
                <ListBox.Template>
                    <ControlTemplate TargetType="ListBox">
                        <Border Background="White" BorderBrush="Black" BorderThickness="1" CornerRadius="5">
                            <ScrollViewer>
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </ListBox.Template>
            </ListBox>
        </StackPanel>
        <Grid Grid.Row="1">
            <StackPanel>
                <Label Content="Сообщение" FontWeight="Medium"/>
                <TextBox Text="{Binding MessageText,UpdateSourceTrigger=PropertyChanged}" Height="61">
                    <TextBox.Template>
                        <ControlTemplate TargetType="TextBox">
                            <Border Background="White" BorderBrush="Black" BorderThickness="1" CornerRadius="5">
                                <ScrollViewer x:Name="PART_ContentHost"/>
                            </Border>
                        </ControlTemplate>
                    </TextBox.Template>
                </TextBox>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="117"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Command="{Binding SendMessageCommand}" Width="116" Height="28" >
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                        <Border Background="#D9D9D9" BorderBrush="Black" BorderThickness="1" CornerRadius="5">
                            <ContentPresenter Content="Отправить" HorizontalAlignment="Center" VerticalAlignment="Center">
                            </ContentPresenter>
                        </Border>
                    </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
